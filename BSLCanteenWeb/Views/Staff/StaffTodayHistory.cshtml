
@{
    ViewBag.Title = "StaffTodayHistory";
}


@{
    <script src="~/Scripts/jquery-3.4.1.min.js"></script>
    <link href="~/Web/css/select2.min.css" rel="stylesheet" />

    <script type="text/javascript">

        $(document).ready(function () {

            var CurrentDate = new Date();

            var day = String(CurrentDate.getDate()).padStart(2, '0');
            var months = ["Jan", "Feb", "Mar", "Apr", "May", "Jun",
                "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
            var month = months[CurrentDate.getMonth()];
            var year = CurrentDate.getFullYear();

            var formattedDate = day + "-" + month + "-" + year;
            $("#spnDate").html(formattedDate);
            var spnCanteen = sessionStorage.getItem("CanteenName");
            $("#spCanteen").html(spnCanteen);

            Fn_Get_Coupon_Order();
            Fn_Get_Count_ItemMenu()

        });


        function Fn_Get_Coupon_Order() {

            var CurrentDate = new Date();

            var day = String(CurrentDate.getDate()).padStart(2, '0');
            var months = ["Jan", "Feb", "Mar", "Apr", "May", "Jun",
                "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
            var month = months[CurrentDate.getMonth()];
            var year = CurrentDate.getFullYear();

            var formattedDate = day + "-" + month + "-" + year;

            $("#spnDate").html(formattedDate);

            var clsCouponReport = {};
            clsCouponReport.ModifiedBy = sessionStorage.getItem("LogInID");
            clsCouponReport.OrderStatus = "Scanned";
            clsCouponReport.OrderTakenDate = formattedDate;
            clsCouponReport.CanteenId = sessionStorage.getItem("CanteenId");
            $("#tbody").html('');
            var html = '';

            $.ajax({
                type: "POST",
                url: "/Staff/Fn_Get_Coupon_Order",
                contentType: "application/json; charset=utf-8",
                dataType: "json",
                data: JSON.stringify(clsCouponReport),
                success: function (data) {
                    var obj = JSON.parse(data.message);
                    if (obj[0].vErrorMsg == "Success") {
                        for (var i = 0; i < obj.length; i++) {
                            html += "<tr>";
                            html += "<td>" + obj[i].OrderTakenDate + " " + obj[i].OrderTakenTime + "</td>";
                            html += "<td>" + obj[i].CouponId + "</td>";
                            html += "<td>" + obj[i].EmpId + "</td>";
                            html += "<td>" + obj[i].EmpName + "</td>";
                            if (obj[i].ItemCategory == "Tea") {
                                html += "<td>☕ Tea <b>(₹" + obj[i].Price + ")</b></td>";
                            }
                            else if (obj[i].ItemCategory == "Breakfast") {
                                html += "<td>🍽️ Breakfast <b>(₹" + obj[i].Price + ")</b></td>";
                            }
                            else if (obj[i].ItemCategory == "Thali") {
                                html += "<td>🍛 Thali</td>";
                            }
                            else if (obj[i].ItemCategory == "Mini Thali") {
                                html += "<td>🍛 Mini Thali <b>(₹" + obj[i].Price + ")</b></td>";
                            }
                            else {
                                html += "<td>" + obj[i].ItemCategory + " <b>(₹" + obj[i].Price + ")</b></td>";
                            }

                            html += "</tr>";
                        }
                    }
                    else {
                        html += "<tr>";
                        html += "<td colspan='5' class='text-center'>" + obj[0].vErrorMsg + "</td>";
                        html += "</tr>";
                    }
                    $("#tbody").append(html);
                },
                error: function (err) {
                    alert(err);
                }
            });
        }


        function Fn_Get_Count_ItemMenu() {

            var today = new Date();

            var day = String(today.getDate()).padStart(2, '0');
            var months = ["Jan", "Feb", "Mar", "Apr", "May", "Jun",
                "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
            var month = months[today.getMonth()];
            var year = today.getFullYear();

            var formattedDate = day + "-" + month + "-" + year;

            var clsCountMenuItem = {};
            clsCountMenuItem.OrderTakenDate = formattedDate;
            clsCountMenuItem.CanteenId = sessionStorage.getItem("CanteenId");
            $("#ItemCountRow").html('');
            var html = '';
            $.ajax({
                type: "POST",
                url: '/Admin/Fn_Get_Count_ItemMenu',
                contentType: "application/json; charset=utf-8",
                dataType: "json",
                data: JSON.stringify(clsCountMenuItem),
                success: function (data) {
                    var obj = JSON.parse(data.message);
                    if (obj[0].vErrorMsg == "Success") {
                        var rCount = 1;
                        for (var i = 0; i < obj.length; i++) {
                            if (obj[i].ItemCategory == "Tea") {
                                html += "<div class='col-sm-3'>";
                                html += "<div class='card p-4 food-card" + rCount + "'>";
                                html += "<div style='font-size: 15px; font-weight: 800'>☕ Tea - " + obj[i].CountItem + "</div>";
                                html += "</div>";
                                html += "</div>";
                            }
                            else if (obj[i].ItemCategory == "Breakfast") {
                                html += "<div class='col-sm-3'>";
                                html += "<div class='card p-4 food-card" + rCount + "'>";
                                html += "<div style='font-size: 15px; font-weight: 800'>🍽️ Breakfast - " + obj[i].CountItem + "</div>";
                                html += "</div>";
                                html += "</div>";
                            }
                            else if (obj[i].ItemCategory == "Thali") {
                                html += "<div class='col-sm-3'>";
                                html += "<div class='card p-4 food-card" + rCount + "'>";
                                html += "<div style='font-size: 15px; font-weight: 800'>🍛 Thali - " + obj[i].CountItem + "</div>";
                                html += "</div>";
                                html += "</div>";
                            }
                            else if (obj[i].ItemCategory == "Mini Thali") {
                                html += "<div class='col-sm-3'>";
                                html += "<div class='card p-4 food-card" + rCount + "'>";
                                html += "<div style='font-size: 15px; font-weight: 800'>🍛 Mini Thali - " + obj[i].CountItem + "</div>";
                                html += "</div>";
                                html += "</div>";
                            }
                            else {
                                html += "<div class='col-sm-3'>";
                                html += "<div class='card p-4 food-card" + rCount + "'>";
                                html += "<div style='font-size: 15px; font-weight: 800'>" + obj[i].ItemCategory + " - " + obj[i].CountItem + "</div>";
                                html += "</div>";
                                html += "</div>";
                            }
                            rCount++;
                        }
                        $("#ItemCountRow").append(html);
                    }
                    else {

                    }

                },
                error: function (err) {
                    alert(err);
                }
            });
        }

    </script>

    <style>
        .food-card1 {
            background-color: #D7CCC8; /* Light Brown */
            border-radius: 12px;
            border: none;
            box-shadow: 0 8px 15px rgba(121, 85, 72, 0.25);
        }

        .food-card2 {
            background-color: #C8E6C9; /* Light Green */
            border-radius: 12px;
            border: none;
            box-shadow: 0 8px 15px rgba(76, 175, 80, 0.25);
        }

        .food-card3 {
            background-color: #FFCCBC; /* Light Orange */
            border-radius: 12px;
            border: none;
            box-shadow: 0 8px 15px rgba(255, 87, 34, 0.25);
        }

        .food-card4 {
            background-color: #E1BEE7; /* Light Purple */
            border-radius: 12px;
            border: none;
            box-shadow: 0 8px 15px rgba(156, 39, 176, 0.25);
        }
    </style>
}


<div class="container mt-4">
    <div class="row">
        <div class="col-12 col-md-12 col-sm-12">

            <h4><span id="spCanteen"></span> — Today's Records</h4>
            <p>Today's <span id="spnDate"></span> Transactions</p>
            <div class="row" id="ItemCountRow">

            </div>
            <div class="card">
                <div class="table-responsive mt-3">
                    <table class="table table-bordered table-hover">
                        <thead>
                            <tr style="background-color: #06BBCC; background-image: linear-gradient(to bottom, #10D4E6, #1BCEDE); color: white;">
                                <th>Issue Date</th>
                                <th>Coupon ID</th>
                                <th>Emp ID</th>
                                <th>Name</th>
                                <th>Item</th>
                            </tr>
                        </thead>
                        <tbody id="tbody">
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

