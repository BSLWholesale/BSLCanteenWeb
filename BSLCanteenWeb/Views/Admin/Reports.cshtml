        function Fn_Fill_DropdownList(ddlName, strTBLName, strFieldName, strValueField, strCriteria) {
            var clsRequestDropdown = {};
            clsRequestDropdown.vFieldName = strFieldName;
            clsRequestDropdown.vValueField = strValueField;
            clsRequestDropdown.vTBLName = strTBLName;
            clsRequestDropdown.vCriteria = strCriteria;
            $("#" + ddlName).html('');
            var dropdown = ''; var dropdown1 = "";
            dropdown1 = "<option value='0'>--Select--</option>";
            $("#" + ddlName).append(dropdown1);
            $.ajax({
                type: "POST",
                url: '/Home/Fn_Fill_DropdownList',
                contentType: "application/json; charset=utf-8",
                dataType: "json",
                data: JSON.stringify(clsRequestDropdown),
                success: function (data) {
                    var obj = JSON.parse(data.message);
                    for (var i = 0; i < obj.length; i++) {
                        if (strValueField == "") {
                            dropdown += "<option value='" + obj[i].vFieldName + "'>" + obj[i].vFieldName + "</option>";
                        }
                        else {
                            dropdown += "<option value='" + obj[i].vValueField + "'>" + obj[i].vFieldName + "</option>";
                        }

                    }
                    $("#" + ddlName).append(dropdown);
                },
                error: function (err) {
                    alert(err);
                }
            });
        }



        function formatDate(date) {
            var day = String(date.getDate()).padStart(2, '0');
            var months = ["Jan", "Feb", "Mar", "Apr", "May", "Jun",
                "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
            var month = months[date.getMonth()];
            var year = date.getFullYear();

            return day + "-" + month + "-" + year;
        }

        function Fn_CanteenWise_Report() {

            var today = new Date();
            var clsMonthlyReportReq = {};
            clsMonthlyReportReq.OrderStatus = "Scanned";
            clsMonthlyReportReq.EmpLocation = sessionStorage.getItem("EmpLocation");

            var ddlDays = $("#ddlDays").val();
            if (ddlDays == "Today") {
                var CurrentDate = new Date(today); // Current date
                clsMonthlyReportReq.ReportType = "Today";
                clsMonthlyReportReq.OrderTakenDate = formatDate(CurrentDate);
            }
            else if (ddlDays == "Monthly") {
                clsMonthlyReportReq.ReportType = "Monthly";

                var fromDate = new Date(today); // Current date
                var toDate = new Date(today);
                if (today.getDate() >= 25) {
                    // Current cycle: 25th of this month to 24th of next month
                    fromDate = new Date(today.getFullYear(), today.getMonth(), 25);
                    toDate = new Date(today.getFullYear(), today.getMonth() + 1, 24);
                } else {
                    // Previous cycle: 25th of previous month to 24th of this month
                    fromDate = new Date(today.getFullYear(), today.getMonth() - 1, 25);
                    toDate = new Date(today.getFullYear(), today.getMonth(), 24);
                }

                clsMonthlyReportReq.FromDate = formatDate(fromDate);
                clsMonthlyReportReq.ToDate = formatDate(toDate);
            }
            else {
                var CurrentDate = new Date(today); // Current date
                clsMonthlyReportReq.ReportType = "Today";
                clsMonthlyReportReq.OrderTakenDate = formatDate(CurrentDate);
            }

            if ($("#ddlCanteen").val() != "0") {
                clsMonthlyReportReq.CanteenName = $("#ddlCanteen").val();
            }


            $("#tbodyCanteen").html('');
            var html = '';
            $.ajax({
                type: "POST",
                url: "/Admin/Fn_CanteenWise_Report",
                contentType: "application/json; charset=utf-8",
                dataType: "json",
                data: JSON.stringify(clsMonthlyReportReq),
                success: function (data) {
                    var obj = JSON.parse(data.message);
                    if (obj[0].vErrorMsg == "Success") {

                        var previousCanteen = "";
                        var totalCoupons = 0;
                        var totalPrice = 0;

                        var grandTotalCoupons = 0;
                        var grandTotalPrice = 0;

                        for (var i = 0; i < obj.length; i++) {

                            if (i == 0 && ddlDays == "Monthly") {
                                html += "<tr style='font-weight:bold;background-color:#e9ecef;'>";
                                html += "<th style='text-align:center;'>Report</th>";
                                html += "<th style='text-align:center;'>From</th>";
                                html += "<th style='text-align:center;'>" + clsMonthlyReportReq.ToDate + "</th>";
                                html += "<th style='text-align:center;'>To</th>";
                                html += "<th style='text-align:center;'>" + clsMonthlyReportReq.FromDate + "</th>";
                                html += "</tr>";
                            }
                            // If canteen changes, display totals for previous canteen
                            if (previousCanteen != "" && previousCanteen != obj[i].CanteenName) {

                                html += "<tr style='font-weight:bold;background:#f2f2f2;'>";
                                html += "<th align='left'>Total (" + previousCanteen + ")</th>";
                                html += "<th></th>";
                                html += "<th></th>";
                                html += "<th style='text-align:right;'>" + totalCoupons + "</th>";
                                html += "<th style='text-align:right;'>" + totalPrice.toFixed(2) + "</th>";
                                html += "</tr>";

                                // Reset totals
                                totalCoupons = 0;
                                totalPrice = 0;
                            }

                            previousCanteen = obj[i].CanteenName;

                            totalCoupons += parseInt(obj[i].TotalCoupons || 0);
                            totalPrice += parseFloat(obj[i].TotalPrice || 0);

                            grandTotalCoupons += parseInt(obj[i].TotalCoupons || 0);
                            grandTotalPrice += parseFloat(obj[i].TotalPrice || 0);

                            html += "<tr>";
                            html += "<td>" + obj[i].CanteenName + "</td>";
                            html += "<td>" + obj[i].OrderTakenDate + "</td>";

                            if (obj[i].ItemCategory == "Tea") {
                                html += "<td class='clsmenu'>☕ Tea</td>";
                            }
                            else if (obj[i].ItemCategory == "Thali") {
                                html += "<td class='clsmenu'>🍛 Thali</td>";
                            }
                            else if (obj[i].ItemCategory == "Mini Thali") {
                                html += "<td class='clsmenu'>🍛 Mini Thali</td>";
                            }
                            else if (obj[i].ItemCategory == "Breakfast") {
                                html += "<td class='clsmenu'>🍽️ Breakfast</td>";
                            }
                            else {
                                html += "<td>" + obj[i].ItemCategory + "</td>";
                            }

                            html += "<td style='text-align:right;'>" + obj[i].TotalCoupons + "</td>";
                            html += "<td style='text-align:right;'>" + obj[i].TotalPrice + "</td>";
                            html += "</tr>";
                        }

                        // Total row for last canteen
                        if (previousCanteen != "") {
                            html += "<tr style='font-weight:bold;background:#f2f2f2;'>";
                            html += "<th align='left'>Total (" + previousCanteen + ")</th>";
                            html += "<th></th>";
                            html += "<th></th>";
                            html += "<th style='text-align:right;'>" + totalCoupons + "</th>";
                            html += "<th style='text-align:right;'>" + totalPrice.toFixed(2) + "</th>";
                            html += "</tr>";
                        }

                        // Grand Total Row
                        html += "<tr style='font-weight:bold;background:#d9edf7;color:#000;'>";
                        html += "<th align='left'>Grand Total</th>";
                        html += "<th></th>";
                        html += "<th></th>";
                        html += "<th style='text-align:right;'>" + grandTotalCoupons + "</th>";
                        html += "<th style='text-align:right;'>" + grandTotalPrice.toFixed(2) + "</th>";
                        html += "</tr>";


                        $("#tbodySummery").html('');
                        $("#tblSummery").hide();

                        $("#tbodyEmp").html('');
                        $("#tblEmp").hide();

                        $("#tbodyEmpSummery").html('');
                        $("#tblEmpSummery").hide();
                    }
                    else {
                        html += "<tr>";
                        html += "<td colspan='5' class='text-center'>" + obj[0].vErrorMsg + "</td>";
                        html += "</tr>";

                        $("#tbodySummery").html('');
                        $("#tblSummery").hide();
                        $("#tbodyEmp").html('');
                        $("#tblEmp").hide();
                        $("#tbodyEmpSummery").html('');
                        $("#tblEmpSummery").hide();
                    }

                    $("#tbodyCanteen").append(html);
                    $("#tblCanteen").show();
                },
                error: function (err) {
                    alert(err);

                }
            });
        }

