        function onRadioChange() {

            var selectedValue = $('input[name="rb"]:checked').val();
            if (selectedValue == "Canteenwise") {
                Fn_CanteenWise_Report();
            } else if (selectedValue == "Employeewise") {
                Fn_EmployeeWise_Report();
            }
            else if (selectedValue == "CanteenwiseSummery") {
                Fn_CanteenWise_Summery();
            }
            else if (selectedValue == "EmployeewiseSummery") {
                Fn_EmployeeWise_Summery();
            }
            else {

            }
        }


        function Fn_ExportExcel() {

            var tab = "";
            var strFileName = "";

            var ddlDays = $("#ddlDays").val();
            var selectedValue = $('input[name="rb"]:checked').val();

            if (selectedValue == "Canteenwise") {
                tab = document.getElementById('tblCanteen');
                strFileName = "Canteenwise-Detail-" + ddlDays;
            }
            else if (selectedValue == "Employeewise") {
                tab = document.getElementById('tblEmp');
                strFileName = "Employeewise-Detail-" + ddlDays;
            }
            else if (selectedValue == "CanteenwiseSummery") {
                tab = document.getElementById('tblSummery');
                strFileName = "Canteenwise-Summery-" + ddlDays;
            }
            else if (selectedValue == "EmployeewiseSummery") {
                tab = document.getElementById('tblEmpSummery');
                strFileName = "Employeewise-Summery-" + ddlDays;
            }

            var tab_text = "<table border='2px'>";

            for (var j = 0; j < tab.rows.length; j++) {

                tab_text += "<tr>";

                var cells = tab.rows[j].cells;

                for (var i = 0; i < cells.length; i++) {

                    var cellValue = "";
                    var tagName = cells[i].tagName.toLowerCase();

                    // Check if td has class="clsmenu"
                    if (cells[i].classList.contains("clsmenu")) {

                        // Export only plain text
                        cellValue = cells[i].textContent
                            .replace(/☕/g, "")
                            .replace(/🍛/g, "")
                            .replace(/🍽️/g, "")
                            .replace(/\s+/g, " ")
                            .trim();

                    } else {

                        // Normal text
                        cellValue = cells[i].innerText.trim();
                    }

                    if (tagName === "th") {

                        tab_text += "<th bgcolor='#87AFC6'>" + cellValue + "</th>";

                    }
                    else if (i === 0) {

                        tab_text += "<td style=\"mso-number-format:'0';\">" + cellValue + "</td>";

                    }
                    else {

                        tab_text += "<td>" + cellValue + "</td>";
                    }
                }

                tab_text += "</tr>";
            }

            tab_text += "</table>";

            // Remove unwanted HTML elements
            tab_text = tab_text.replace(/<A[^>]*>|<\/A>/gi, "");
            tab_text = tab_text.replace(/<img[^>]*>/gi, "");
            tab_text = tab_text.replace(/<input[^>]*>|<\/input>/gi, "");

            var ua = window.navigator.userAgent;
            var msie = ua.indexOf("MSIE ");

            var sa = "";

            if (msie > 0 || !!navigator.userAgent.match(/Trident.*rv\:11\./)) {

                txtArea1.document.open("txt/html", "replace");
                txtArea1.document.write(tab_text);
                txtArea1.document.close();
                txtArea1.focus();

                sa = txtArea1.document.execCommand(
                    "SaveAs",
                    true,
                    strFileName + ".xls"
                );

            } else {

                var blob = new Blob(
                    [tab_text],
                    {
                        type: "application/vnd.ms-excel"
                    }
                );

                var link = document.createElement("a");

                link.href = URL.createObjectURL(blob);
                link.download = strFileName + ".xls";

                document.body.appendChild(link);
                link.click();

                document.body.removeChild(link);
            }

            return sa;
        }

    </script>
}


