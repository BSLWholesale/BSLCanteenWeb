                                    html += "<div style='font-size: 15px'>Item: ☕ Tea (<strong>₹" + obj[i].Price + ")</strong></div>";
                                }
                                else if (obj[i].ItemCategory == "Breakfast") {
                                    html += "<div style='font-size: 15px'>Item: 🍽️ Breakfast (<strong>₹" + obj[i].Price + ")</strong></div>";
                                }
                                else if (obj[i].ItemCategory == "Thali") {
                                    html += "<div style='font-size: 15px'>Item: 🍛 Thali (<strong>₹" + obj[i].Price + ")</strong></div>";
                                }
                                else if (obj[i].ItemCategory == "Mini Thali") {
                                    html += "<div style='font-size: 15px'>Item: 🍛 Mini Thali (<strong>₹" + obj[i].Price + ")</strong></div>";
                                }
                                else {
                                    html += "<div style='font-size: 15px'>Item: " + obj[i].ItemCategory + "</div>";
                                }
                                html += "<div>CId: " + obj[i].CouponId + "</div>";
                                html += "<div>Issued: " + obj[i].CouponIssueDate + "</div>";
                                html += "<div>Canteen: " + obj[i].CanteenName + "</div>";
                                html += "<div>Code: " + obj[i].EmpId + "</div>";
                                html += "</div>";
                                html += "<div id='gen-qr-wrap_" + i + "' style='width:90px; height:90px; display:flex; align-items:center; justify-content:center; margin-top:10px;'></div>";
                                html += "</div>";
                                html += "<div>Name: " + obj[i].EmpName + "</div>";
                                html += "</div>";
                                html += "</div>";
                                html += "</div>";
                            }

                            $("#dvA4Size").append(html);

                            for (var i = 0; i < obj.length; i++) {

                                var text = "" + obj[i].CouponId + "";

                                var qrcode = new QRCode(document.getElementById("gen-qr-wrap_" + i), {
                                    width: 90,
                                    height: 90
                                });

                                qrcode.makeCode(text);
                            }
                            $("#dvA4Size").show();
                            $("#btnPrintA4").show();
                            $("#btnPrintCard").hide();
                            $("#dvQR").html('');
                        }
                        else {
                            $("#btnPrintA4").hide();
                        }
                    },
                    error: function (err) {
                        alert(err);

                    }
                });
            }
        }

        function Print_A4_Coupon() {

            var printContents = document.getElementById("dvA4Size").innerHTML;
            var printWindow = window.open('', '', 'width=900,height=700');

            printWindow.document.write(`
             <!DOCTYPE html>
             <html>
             <head>
                 <title>Print Coupons</title>             
                 <style>             
                     @@page {
                         size: A4 portrait;
                         margin: 10mm;
                     }
             
                     *{
                         box-sizing:border-box;
                     }
             
                     body{
                         margin:0;
                         padding:0;
                         font-family:Arial,sans-serif;
                     }
             
                     /* 3 Coupons Per Row */
                     #dvA4Size{
                         display:grid;
                         grid-template-columns:repeat(3,1fr);
                         width:100%;
                     }
             
                     .col-sm-4{
                         padding:10px;
             
                         /* Horizontal & Vertical Dotted Cut Lines */
                         border-right:2px dotted #000;
                         border-bottom:2px dotted #000;
             
                         page-break-inside:avoid;
                         break-inside:avoid;
                     }
             
                     /* Remove right dotted line on last column */
                     .col-sm-4:nth-child(3n){
                         border-right:none;
                     }
             
                     .card{
                         border:1px solid #000;
                         padding:8px;
                         min-height:180px;
                     }
             
                     .qr-card{
                         page-break-inside:avoid;
                         break-inside:avoid;
                     }
             
                     img{
                         max-width:100%;
                     }             
                 </style>             
             </head>             
             <body>             
                 <div id="dvA4Size">
                     ${printContents}
                 </div>             
             </body>
             </html>
             `);

            printWindow.document.close();

            printWindow.onload = function () {
                printWindow.focus();
                printWindow.print();
                printWindow.close();
            };
        }

    </script>
}


<div class="container mt-4">
    <div class="row">
        <div class="col-8">
            <h4>Issue / Recharge Coupon</h4>
            <div class="card pb-5">
                <div class="row mb-3 mt-3">
                    <div class="col-sm-4">
                        <div class="form-group">
                            <label>Employee No.</label>
                            <select id="ddlEmpName" class="form-control" onchange="Fn_OnChange_ddlEmpName()" style="width: 100%;">
                                <option value="0">--Select--</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-sm-4">
                        <div class="form-group">
                            <label>Emp Location</label>
                            <select id="ddlEmpLocation" class="form-control" onchange="Fn_OnChange_ddlEmpLocation()" style="width: 100%;">
                                <option value="0">--Select--</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-sm-4">
                        <div class="form-group">
                            <label>Assign Canteen</label>
                            <select id="ddlCanteen" class="form-control" style="width: 100%;">
                                <option value="0">--Select--</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="row mb-3" id="dvMenuItem">

                </div>
                <div class="row">
                    <div class="col-12">
                        <button class="btn btn-primary" style="width:100%" onclick="Fn_Emp_CouponGeneration();">Generate Coupon & QR Code</button>
                    </div>
                    <div class="col-12 mt-2">
                        <div class="row">
                            <div class="col-sm-6">
                                <button class="btn btn-success" style="width:100%" onclick="Fn_Get_Coupon_Order();">View Sticker</button>
                            </div>
                            <div class="col-sm-6">
                                <button class="btn btn-success" style="width:100%" onclick="Fn_Get_A4_Coupon_Order();">View A4</button>
                            </div>
                        </div>

                    </div>
                    <div class="col-12 mt-2">
                        <button id="btnPrintCard" style="display:none; width: 100%;" class="btn btn-primary" onclick="printQRCoupons();">🖨 Print Card</button>
                        <button id="btnPrintA4" style="display:none; width: 100%;" class="btn btn-primary" onclick="Print_A4_Coupon();">🖨 Print A4</button>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-4">
            <h5>Generated Card</h5>
            <div id="dvQR" style="max-height: 500px; overflow-y: auto;">
            </div>

        </div>
    </div>

    <div class="row" id="dvA4Size">

    </div>
</div>
<!-- Team End -->
<script src="~/Web/js/select2.min.js"></script>
<script>
    $(function () {
        $("#ddlEmpName").select2();
        $("#ddlCanteen").select2();
        $("#ddlEmpLocation").select2();

    });

</script>