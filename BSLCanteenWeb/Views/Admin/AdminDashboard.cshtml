            if ($("#ddlEmpName").val() == "0") {
                Swal.fire({ title: "", text: "Please Select Employee", icon: "error" });
            }
            else if ($("#ddlCanteen").val() == "0") {
                Swal.fire({ title: "", text: "Please Select Canteen", icon: "error" });
            }
            else if (clsCouponOrder.Items.length == 0 || clsCouponOrder.Items.length == null) {
                Swal.fire({ title: "", text: "Please Select Item Menu", icon: "error" });
            }
            else {
                $.ajax({
                    type: "POST",
                    url: "/Admin/Fn_Emp_CouponGeneration",
                    contentType: "application/json; charset=utf-8",
                    dataType: "json",
                    data: JSON.stringify(clsCouponOrder),
                    success: function (data) {
                        var obj = JSON.parse(data.message);
                        if (obj.vErrorMsg == "Success") {
                            Swal.fire({ title: "", text: "Order Placed Successfully.", icon: "success" });
                        }
                        else {
                            Swal.fire({ title: "", text: obj.vErrorMsg, icon: "error" });
                        }
                    },
                    error: function (err) {
                        alert(err);

                    }
                });
            }

        }

        function Fn_Get_Coupon_Order() {

            var clsCouponOrder = {};
            clsCouponOrder.CreatedBy = sessionStorage.getItem("LogInID");
            clsCouponOrder.EmpId = $("#ddlEmpName").val();
            $("#issue-preview-box").html('');
            var html = '';
            $.ajax({
                type: "POST",
                url: "/Admin/Fn_Get_Coupon_Order",
                contentType: "application/json; charset=utf-8",
                dataType: "json",
                data: JSON.stringify(clsCouponOrder),
                success: function (data) {
                    var obj = JSON.parse(data.message);
                    if (obj[0].vErrorMsg == "Success") {
                        for (var i = 0; i < obj.length; i++) {
                            html += "<div class='qr-card' id='gen-qr-card_" + i + "'>";
                            html += "<div style='display:flex; align-items:center; justify-content:space-between; gap:10px; margin-bottom:10px;'>";
                            html += "<img src='/Web/img/banswara_logo.png' style='width:80px; height:auto;' />";
                            html += "<div id='gen-qr-wrap_" + i + "' style='width:100px; height:100px; display:flex; align-items:center; justify-content:center;'></div>";
                            html += "</div>";
                            html += "<div class='qr-canteen-band'>CouponId: " + obj[i].CouponId + "</div>";
                            html += "<div class='qr-canteen-band'>Name: " + obj[i].EmpName + " (" + obj[i].EmpId +")</div>";
                            html += "<div class='qr-canteen-band'>Item: " + obj[i].ItemCategory + "</div>";
                            html += "<div class='qr-canteen-band'>Canteen: " + obj[i].CanteenName + "</div>";
                            html += "<div class='qr-canteen-band'>Date: " + obj[i].CouponIssueDate + "</div>";
                            html += "</div>";

                        }

                        $("#issue-preview-box").append(html);

                        for (var i = 0; i < obj.length; i++) {

                            var text = obj[i].CouponId; 

                            var qrcode = new QRCode(document.getElementById("gen-qr-wrap_" + i), {
                                width: 70,
                                height: 70
                            });

                            qrcode.makeCode(text);
                        }
                        $("#issue-print-btn").show();
                    }
                    else {
                        $("#issue-print-btn").hide();
                    }
                },
                error: function (err) {
                    alert(err);

                }
            });
        }

        function printQRCoupons() {

    var printContents = document.getElementById("issue-preview-box").innerHTML;

    var printWindow = window.open('', '', 'width=900,height=700');

    printWindow.document.write(`
        <html>
        <head>
            <title>Print QR Stickers</title>

            <style>
                body{
                    margin:0;
                    padding:10px;
                    font-family:Arial, sans-serif;
                }

                .qr-card{
                    width:3in;
                    border:1px solid #000;
                    padding:8px;
                    margin:10px auto;
                    box-sizing:border-box;
                    page-break-inside:avoid;
                }

                .qr-canteen-band{
                    font-size:12px;
                    font-weight:bold;
                    margin:3px 0;
                }

                .qr-card img{
                    width:80px;
                }

                @@page{
                    margin:0.2in;
                }
            </style>
        </head>

        <body>
            ${printContents}
        </body>
        </html>
    `);

    printWindow.document.close();

    printWindow.onload = function () {
        printWindow.focus();
        printWindow.print();
        printWindow.close();
    };
}

    </script>

