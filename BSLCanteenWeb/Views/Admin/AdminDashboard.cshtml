                                    ${canAfford.length ? canAfford.map(m => `<div style="display:flex;align-items:center;gap:8px;padding:6px 0;border-bottom:1px solid var(--border);font-size:13px;">${m.icon} <strong>${m.name}</strong> <span style="color:var(--muted);margin-left:auto;">₹${m.price}</span></div>`).join('') : `<div style="font-size:13px;color:var(--danger);">Insufficient balance for any item. Please contact admin.</div>`}`;
        }

        // ── EMPLOYEE HISTORY ──
        function renderEmpHistory() {
            const empNo = SESSION.empNo; const emp = getEmp(empNo); const cpn = getCoupon(empNo); const c = getC(cpn.canteenId);
