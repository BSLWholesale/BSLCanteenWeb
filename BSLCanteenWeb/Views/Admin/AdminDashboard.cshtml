        // ── REPORTS ──
        function renderReports() {
            const totalSales = TRANSACTIONS.reduce((a, t) => a + t.amount, 0);
            const totalTxn = TRANSACTIONS.length;
            const itemCounts = {};
            TRANSACTIONS.forEach(t => { itemCounts[t.item] = (itemCounts[t.item] || 0) + t.amount; });
            document.getElementById('report-stats').innerHTML = `
                                    <div class="stat-card"><div class="stat-ic" style="background:var(--warn-lt);">💳</div><div class="stat-num">₹${totalSales}</div><div class="stat-lbl">Total Revenue</div></div>
                                    <div class="stat-card"><div class="stat-ic" style="background:var(--accent-lt);">🔢</div><div class="stat-num">${totalTxn}</div><div class="stat-lbl">Transactions</div></div>
                                    <div class="stat-card"><div class="stat-ic" style="background:var(--success-lt);">📅</div><div class="stat-num">₹${Math.round(totalSales / 7)}</div><div class="stat-lbl">Avg per Canteen</div></div>
                                    <div class="stat-card"><div class="stat-ic" style="background:#EEE9FB;">🍽️</div><div class="stat-num">${Math.round(totalSales / Math.max(totalTxn, 1))}</div><div class="stat-lbl">Avg Txn (₹)</div></div>
                                  `;
            document.getElementById('item-breakdown').innerHTML = MENU.map(m => {
                const sales = itemCounts[m.name] || 0;
                const count = TRANSACTIONS.filter(t => t.item === m.name).length;
                const pct = Math.round(sales / (totalSales || 1) * 100);
                return `<div style="margin-bottom:14px;">
                                      <div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:4px;">
                                        <span>${m.icon} <strong>${m.name}</strong> (${count} orders)</span><span style="color:var(--accent);font-weight:700;">₹${sales}</span>
                                      </div>
                                      <div class="balance-bar-track"><div class="balance-bar-fill" style="width:${pct}%;background:var(--accent2);"></div></div>
                                    </div>`;
            }).join('');

            const canteenSales = CANTEENS.map(c => ({ c, val: TRANSACTIONS.filter(t => t.canteenId === c.id).reduce((a, t) => a + t.amount, 0) }));
            const maxV = Math.max(...canteenSales.map(x => x.val), 1);
            document.getElementById('canteen-bar').innerHTML = `<div class="bar-chart">` + canteenSales.map(({ c, val }) =>
                `<div class="bar-col"><div style="font-size:10px;color:var(--muted);font-weight:700;">₹${val}</div><div class="bar-fill-v" style="height:${Math.round(val / maxV * 90)}px;background:${c.color};"></div><div class="bar-lbl">${c.id}</div></div>`
            ).join('') + '</div>';

            document.getElementById('all-txn-tbl').innerHTML = [...TRANSACTIONS].reverse().map(t => {
                const e = getEmp(t.empNo) || { name: t.empNo }; const c = getC(t.canteenId); const mi = MENU.find(m => m.name === t.item);
                return `<tr>
                                      <td><code style="font-size:11px;">${t.txnId}</code></td>
                                      <td style="font-size:12px;">${t.dt.replace('T', ' ').slice(0, 16)}</td>
                                      <td><code style="font-size:12px;">${t.empNo}</code></td>
                                      <td>${e.name}</td>
                                      <td><span class="chip-canteen" style="background:${c.lt};color:${c.color};">${c.emoji} ${c.name}</span></td>
                                      <td>${mi?.icon} ${t.item}</td>
                                      <td><strong>₹${t.amount}</strong></td>
                                      <td>₹${t.balAfter}</td>
                                    </tr>`;
            }).join('');
        }

        // ── STAFF POS ──
        function renderStaffPOS() {
            const c = getC(SESSION.canteenId);
            document.getElementById('staff-canteen-title').textContent = `Point of Sale — ${c?.name || ''}`;
            document.getElementById('menu-grid').innerHTML = MENU.map(m => `
                                    <div class="menu-item" id="mi-${m.id}" onclick="selectMenuItem('${m.id}')">
                                      <div class="menu-icon">${m.icon}</div>
                                      <div class="menu-name">${m.name}</div>
