                                    ${MENU.map(m => { const cnt = myTxn.filter(t => t.item === m.name).length; return `<div class="stat-card"><div class="stat-ic" style="background:var(--bg);">${m.icon}</div><div class="stat-num">${cnt}</div><div class="stat-lbl">${m.name}</div></div>`; }).join('')}
