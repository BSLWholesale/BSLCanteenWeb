            const e = getEmp(empNo); const c = getC(cid);
            const expiry = new Date(); expiry.setDate(expiry.getDate() + days);
            const expiryStr = expiry.toISOString().split('T')[0];
            const cpnId = `CP-${cid}-${empNo}`;
            COUPONS[empNo] = { canteenId: cid, balance: bal, initialBalance: bal, expiry: expiryStr, couponId: cpnId };
            const box = document.getElementById('issue-preview-box');
            box.innerHTML = `<div class="qr-card" id="gen-qr-card">
                                    <div style="font-size:10px;color:var(--muted);font-weight:700;letter-spacing:1px;margin-bottom:6px;">CANTEENPASS · ABC INDUSTRIES</div>
                                    <div id="gen-qr-wrap"></div>
                                    <div class="qr-card-name">${(obj[0].EmpName)}</div>
                                    <div class="qr-card-id">Emp No: ${empNo} · ${cpnId}</div>
                                    <div class="qr-canteen-band" style="background:${c.color};color:#fff;">${c.emoji} ${obj[0].CanteenName}<br/><span style="font-size:11px;opacity:0.8;">${c.loc}</span></div>
                                    <div class="qr-balance">₹${bal}</div>
                                    <div class="qr-balance-lbl">Prepaid Balance</div>
                                    <div style="margin-top:8px;font-size:11px;color:var(--muted);">Valid until ${expiryStr}</div>
                                    <div style="margin-top:6px;font-size:10px;color:var(--muted);border-top:1px dashed var(--border);padding-top:6px;">Valid at ${obj[0].CanteenName} only</div>
