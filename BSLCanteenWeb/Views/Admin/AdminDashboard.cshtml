            setTimeout(() => {
                const el = document.getElementById('emp-qr-render');
                if (el) new QRCode(el, { text: `canteenpass/emp/${empNo}/canteen/${cpn.canteenId}`, width: 110, height: 110, correctLevel: QRCode.CorrectLevel.M });
            }, 80);

            document.getElementById('emp-stats').innerHTML = `
                                    <div class="stat-card"><div class="stat-ic" style="background:${barColor}20;">${pct > 30 ? '💚' : pct > 10 ? '⚠️' : '🔴'}</div><div class="stat-num" style="color:${barColor};">₹${cpn.balance}</div><div class="stat-lbl">Balance</div></div>
                                    <div class="stat-card"><div class="stat-ic" style="background:var(--bg);">🍽️</div><div class="stat-num">${TRANSACTIONS.filter(t => t.empNo === empNo).length}</div><div class="stat-lbl">Meals Used</div></div>
                                  `;

            document.getElementById('emp-bal-bar').innerHTML = `
