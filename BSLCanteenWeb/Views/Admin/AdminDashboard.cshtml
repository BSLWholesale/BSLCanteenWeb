                                      <div style="font-size:11px;color:var(--muted);margin-top:2px;">${m.desc}</div>
                                    </div>`).join('');
            if (selectedMenuItem) document.getElementById('mi-' + selectedMenuItem)?.classList.add('selected');
        }
        function selectMenuItem(id) {
            selectedMenuItem = id;
            document.querySelectorAll('.menu-item').forEach(el => el.classList.remove('selected'));
            document.getElementById('mi-' + id)?.classList.add('selected');
            clearPosResult();
        }
        function clearPosResult() { document.getElementById('pos-result').innerHTML = ''; }

        function processTransaction() {
            const input = document.getElementById('pos-scan-input').value.trim();
            const res = document.getElementById('pos-result');
            if (!selectedMenuItem) { res.innerHTML = `<div class="result-fail"><div class="result-icon">⚠️</div><div class="result-title">Select a menu item first</div></div>`; return; }
            const menuItem = MENU.find(m => m.id === selectedMenuItem);
            const empNo = input;
            const emp = getEmp(empNo);
            if (!emp) { res.innerHTML = `<div class="result-fail"><div class="result-icon">❌</div><div class="result-title">Employee not found</div><div class="result-sub">No employee with ID "${input}"</div></div>`; return; }
            const cpn = getCoupon(empNo);
            if (!cpn) { res.innerHTML = `<div class="result-fail"><div class="result-icon">🚫</div><div class="result-title">No coupon assigned</div><div class="result-sub">${emp.name} has no prepaid coupon. Contact admin.</div></div>`; return; }
            if (cpn.canteenId !== SESSION.canteenId) {
                const empC = getC(cpn.canteenId); const myC = getC(SESSION.canteenId);
                res.innerHTML = `<div class="result-fail"><div class="result-icon">🚫</div><div class="result-title">Wrong canteen</div><div class="result-sub">${emp.name}'s coupon is for <strong>${empC?.name}</strong>.<br/>Please go to ${empC?.name}.</div></div>`; return;
            }
            if (cpn.balance <= 0) { res.innerHTML = `<div class="result-fail"><div class="result-icon">💸</div><div class="result-title">Balance exhausted</div><div class="result-sub">${emp.name} has ₹0 balance. Please recharge.</div></div>`; return; }
            if (cpn.balance < menuItem.price) { res.innerHTML = `<div class="result-fail"><div class="result-icon">💸</div><div class="result-title">Insufficient balance</div><div class="result-sub">Balance ₹${cpn.balance} is less than ₹${menuItem.price} for ${menuItem.name}</div></div>`; return; }

            // Deduct
            cpn.balance -= menuItem.price;
            const txnId = `TXN${String(txnCounter++).padStart(3, '0')}`;
            const now = new Date().toISOString();
            TRANSACTIONS.push({ txnId, empNo, canteenId: SESSION.canteenId, item: menuItem.name, amount: menuItem.price, balAfter: cpn.balance, dt: now });

            const c = getC(SESSION.canteenId);
            const pct = Math.round(cpn.balance / cpn.initialBalance * 100);
            const barColor = pct > 30 ? 'var(--success)' : pct > 10 ? 'var(--warn)' : 'var(--danger)';

            res.innerHTML = `
                                    <div class="result-ok" style="margin-bottom:12px;">
                                      <div class="result-icon">✅</div>
                                      <div class="result-title">Transaction Successful!</div>
                                      <div style="font-size:16px;font-weight:800;margin:6px 0;">${emp.name}</div>
                                      <div style="font-size:13px;color:var(--muted);">${menuItem.icon} ${menuItem.name} · <strong style="color:var(--danger);">₹${menuItem.price} deducted</strong></div>
                                    </div>
                                    <div class="card card-pad">
                                      <div style="display:flex;justify-content:space-between;margin-bottom:8px;">
                                        <span style="font-size:13px;color:var(--muted);">Balance after deduction</span>
                                        <strong style="color:${barColor};">₹${cpn.balance}</strong>
                                      </div>
                                      <div class="balance-bar-track"><div class="balance-bar-fill" style="width:${pct}%;background:${barColor};"></div></div>
                                      <div style="font-size:11px;color:var(--muted);margin-top:4px;">₹${cpn.balance} of ₹${cpn.initialBalance} remaining</div>
                                      ${cpn.balance < 50 ? `<div style="margin-top:8px;font-size:12px;color:var(--warn);font-weight:600;">⚠️ Low balance — please recharge soon</div>` : ''}
                                    </div>`;

            document.getElementById('pos-scan-input').value = '';
            toast(`✅ ₹${menuItem.price} deducted — ${emp.name}`);
        }

        // ── STAFF HISTORY ──
        function renderStaffHistory() {
            const c = getC(SESSION.canteenId);
            document.getElementById('staff-hist-sub').textContent = `${c?.name} — Today's records`;
            const myTxn = TRANSACTIONS.filter(t => t.canteenId === SESSION.canteenId);
