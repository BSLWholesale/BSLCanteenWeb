                employee: 'Employee: 43556–43565 / 1234'
            };
            document.getElementById('login-hint').textContent = hints[r];
            document.getElementById('login-id').value = '';
            document.getElementById('login-pass').value = '';
        }

        function doLogin(us) {
            const id = document.getElementById('login-id').value.trim();
            const pass = document.getElementById('login-pass').value.trim();
            const err = document.getElementById('login-err');
            err.textContent = '';

            if (selectedRole === 'admin') {
                const u = USERS.admin.find(u => u.id === id && u.pass === pass);
                if (!u) { err.textContent = 'Invalid admin credentials'; return; }
                SESSION = { ...u };
                launchApp();
            } else if (selectedRole === 'staff') {
                const u = USERS.staff.find(u => u.id === id && u.pass === pass);
                if (!u) { err.textContent = 'Invalid staff credentials'; return; }
                SESSION = { ...u };
                launchApp();
            } else {
                // employee: empNo + pass 1234
                const emp = EMPLOYEES.find(e => e.empNo === id);
                if (!emp || pass !== '1234') { err.textContent = 'Invalid employee credentials'; return; }
                const cpn = getCoupon(id);
                if (!cpn) { err.textContent = 'No coupon assigned. Contact Admin.'; return; }
                SESSION = { role: 'employee', empNo: id, name: emp.name, canteenId: cpn.canteenId };
                launchApp();
            }
        }

