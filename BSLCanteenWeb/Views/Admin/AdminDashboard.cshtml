        function renderEmpWallet() {
            const empNo = SESSION.empNo;
            const emp = getEmp(empNo); const cpn = getCoupon(empNo); const c = getC(cpn.canteenId);
            document.getElementById('emp-greeting').textContent = `Welcome, ${emp.name}`;
