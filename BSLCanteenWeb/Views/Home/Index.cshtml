@{
    ViewBag.Title = "Home Page";
    Layout = null;
}

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<script src="~/Web/js/jquery-3.7.1.min.js"></script>
<script src="~/Web/js/sweetalert2.js"></script>
<link href="~/Web/css/sweetalert2.css" rel="stylesheet" />

<script type="text/javascript">

    function Fn_Login_Employee() {

        if ($("#txtEmployeeId").val() == "") {
            Swal.fire({ title: "Login", text: "Please Enter the Employee ID", icon: "error" });
        }
        else if ($("#txtPassword").val() == "") {
            Swal.fire({ title: "Login", text: "Please Enter the Password", icon: "error" });
        }
        else {
            var clsEmployee = {};
            var employeeValue = $("#txtEmployeeId").val().trim();

            if (/^\d+$/.test(employeeValue)) {
                clsEmployee.EmpId = employeeValue;
                clsEmployee.EmpMobile = employeeValue;
                clsEmployee.EmpPassword = $("#txtPassword").val();
            }
            else if (/^[a-zA-Z0-9]+$/.test(employeeValue)) {
                clsEmployee.LoginID = employeeValue;
                clsEmployee.EmpPassword = $("#txtPassword").val();
            }
            else {
                Swal.fire({ title: "Login", text: "Please enter a valid Employee ID", icon: "error", });
            }
            
            $.ajax({
                type: "POST",
                url: "/Home/Fn_Login_Employee",
                contentType: "application/json; charset=utf-8",
                dataType: "json",
                data: JSON.stringify(clsEmployee),
                success: function (data) {
                    var obj = JSON.parse(data.message);
                    if (obj.vErrorMsg == "Success") {
                        sessionStorage.setItem("LogInID", obj.EmpId);
                        sessionStorage.setItem("EmpName", obj.EmpName);
                        sessionStorage.setItem("EmpMobile", obj.EmpMobile);
                        sessionStorage.setItem("EmpLocation", obj.EmpLocation);
                        sessionStorage.setItem("EmpRole", obj.EmpRole);
                        sessionStorage.setItem("CanteenId", obj.CanteenId);
                        sessionStorage.setItem("CanteenName", obj.CanteenName);
                        sessionStorage.setItem("LoginID", obj.LoginID);
                        if (obj.EmpRole == "Admin") {                            
                            window.location.href = '/Admin/AdminDashboard';
                        }
                        if (obj.EmpRole == "Staff") {
                            window.location.href = '/Staff/StaffDashboard';
                        }
                        if (obj.EmpRole == "Employee") {
                            window.location.href = '/Home/Contact';
                        }
                    }
                    else {
                        Swal.fire({ title: "Login", text: obj.vErrorMsg, icon: "error", });
                    }
                },
                error: function (err) {
                    alert(err);
                }
            });
        }
    }

</script>


<style>
    :root {
        --bg: #F4F3EF;
        --surface: #FFFFFF;
        --border: #E2E0D8;
        --text: #18180F;
        --muted: #6C6C62;
        --accent: #1C3D2E;
        --accent2: #2E6B4A;
        --accent-lt: #E4EFE8;
        --warn: #B85C00;
        --warn-lt: #FDF3E7;
        --danger: #B01C1C;
        --danger-lt: #FBEAEA;
        --success: #1A7A3A;
        --success-lt: #E6F4EB;
        --r: 10px;
        --rs: 6px;
        --shadow: 0 1px 4px rgba(0,0,0,0.08);
    }

    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    body {
        font-family: 'Segoe UI',system-ui,sans-serif;
        background: var(--bg);
        color: var(--text);
        min-height: 100vh;
    }

    /* ── LOGIN ── */
    #login-screen {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg,#fcf7e8 0%,#fcf7e8 100%);
        padding: 1rem;
    }

    .login-card {
        background: var(--surface);
        border-radius: 16px;
        padding: 2.5rem;
        width: 100%;
        max-width: 420px;
        box-shadow: 0 20px 60px rgba(0,0,0,0.25);
    }

    .login-logo {
        text-align: center;
        margin-bottom: 2rem;
    }

    .login-logo-icon {
        margin-bottom: 8px;
    }

    .login-logo h1 {
        font-size: 22px;
        font-weight: 800;
        color: #ff8702;
        letter-spacing: -0.5px;
    }

    .login-logo p {
        font-size: 12px;
        color: var(--muted);
        letter-spacing: 1px;
        text-transform: uppercase;
        margin-top: 2px;
    }


    .form-group {
        margin-bottom: 14px;
    }

    .form-group label {
        display: block;
        font-size: 14px;
        font-weight: 700;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 5px;
    }

    .form-group input, .form-group select {
        width: 100%;
        padding: 11px 14px;
        border-radius: var(--rs);
        border: 1.5px solid var(--border);
        font-size: 14px;
        background: #FFFFFF;
        color: var(--text);
        outline: none;
        transition: border 0.15s;
    }

    .form-group input:focus, .form-group select:focus {
        border-color: var(--accent);
        background: #fff;
    }

    .btn-login {
        width: 100%;
        padding: 13px;
        border-radius: var(--rs);
        border: none;
        background: #ff8702;
        color: #fff;
        font-size: 15px;
        font-weight: 700;
        cursor: pointer;
        transition: opacity 0.15s;
        letter-spacing: 0.3px;
    }

    .btn-login:hover {
        opacity: 0.9;
    }

    .login-hint {
        font-size: 11px;
        color: var(--muted);
        text-align: center;
        margin-top: 12px;
        line-height: 1.6;
    }

    .btn {
        padding: 10px 20px;
        border-radius: var(--rs);
        border: 1px solid var(--border);
        background: var(--surface);
        color: var(--text);
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.15s;
    }

    .btn:hover {
        background: var(--bg);
    }

    .btn-primary {
        background: var(--accent);
        color: #fff;
        border-color: var(--accent);
    }

    .btn-primary:hover {
        opacity: 0.88;
    }

    .btn-danger {
        background: #ff8702;
        color: #fff;
        border-color: #ff8702;
    }

    .btn-full {
        width: 100%;
        padding: 13px;
        font-size: 15px;
    }

    .btn-warn {
        background: var(--warn);
        color: #fff;
        border-color: var(--warn);
    }
</style>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        var input = document.getElementById("txtPassword");
        input.addEventListener("keypress", function (event) {
            if (event.key === "Enter") {
                event.preventDefault();
                Fn_Login_Employee();
            }
        });
    });
</script>

<div id="login-screen">
    <div class="login-card">
        <div class="login-logo">
            <div class="login-logo-icon"><img src="~/Web/img/BanswaraLogo.png" width="50%" height="10%" style="margin-right: 10%;" /></div>
            @*<div class="login-logo-icon">🏭</div>*@
            <h1>Canteen System</h1>
        </div>

        <div class="form-group">
            <label>Employee ID</label>
            <input type="text" id="txtEmployeeId" placeholder="Enter Employee ID" />
        </div>
        <div class="form-group">
            <label>Password</label>
            <input type="password" id="txtPassword" placeholder="Enter Password" />
        </div>
        <button class="btn-login" onclick="Fn_Login_Employee();"><b>Log In</b></button>
    </div>
</div>